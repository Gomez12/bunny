{
  "name": "bunny-electron",
  "version": "0.0.1",
  "private": true,
  "description": "Bunny desktop client (Electron)",
  "author": "Gomez12",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "nl.ez-base.bunny-electron",
    "productName": "Bunny",
    "files": [
      "main.js",
      "preload.js",
      "ui/**/*",
      "icons/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icons/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "artifactName": "BunnyClient-macos-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "BunnyClient-macos-${arch}.${ext}"
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "portable": {
      "artifactName": "BunnyClient-windows-${arch}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "BunnyClient-windows-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": [{ "target": "AppImage", "arch": ["x64", "arm64"] }],
      "artifactName": "BunnyClient-linux-${arch}.${ext}"
    }
  }
}
