{
  "name": "bunny",
  "version": "0.0.6",
  "description": "Bun-native AI agent with queue-backed logging and hybrid memory",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "bunny": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "serve": "bun run src/server/index.ts",
    "serve:watch": "bun --watch src/server/index.ts",
    "web:dev": "bun --cwd web run dev",
    "web:build": "bun --cwd web run build",
    "build": "bun run scripts/build.ts",
    "build:platform": "bun run scripts/build.ts --platform",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun tsc --noEmit",
    "docs": "typedoc",
    "fmt": "bun x prettier --write src tests",
    "check": "bun run typecheck && bun test",
    "client:dev": "bun --cwd client run dev",
    "client:build": "bun --cwd client run build"
  },
  "dependencies": {
    "bunqueue": "latest",
    "docx": "^9.6.1",
    "node-html-markdown": "^1.3.0",
    "jszip": "^3.10.1",
    "sqlite-vec": "latest",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typedoc": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
