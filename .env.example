# Bunny environment variables
# Copy to .env and fill in. Never commit .env.

# --- State layout (portability) -----------------------------------------
# Default: ./.bunny under cwd. Set to override (e.g. /mnt/usb/bunny-state).
# BUNNY_HOME=./.bunny

# --- LLM provider (OpenAI-compatible endpoint) --------------------------
# Any OpenAI-compatible server works: OpenAI, OpenRouter, Ollama, vLLM,
# LiteLLM, DeepSeek, etc. Just point base URL at it.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Reasoning-capable models (example: deepseek-reasoner, o1-mini, o3-mini).
# Leave empty to use LLM_MODEL for both.
# LLM_MODEL_REASONING=deepseek-reasoner

# Provider profile hint. Auto-detected from base URL if unset.
# Valid: openai | deepseek | openrouter | ollama | anthropic-compat
# LLM_PROFILE=openai

# --- Embeddings ---------------------------------------------------------
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-small
# Must match embeddings table dimension in schema.sql (default 1536).
EMBED_DIM=1536

# --- Session -------------------------------------------------------------
# BUNNY_SESSION=some-stable-id
